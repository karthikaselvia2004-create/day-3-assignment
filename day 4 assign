use students;
show tables;

CREATE TABLE Student (
    RollNo INT,
    Name VARCHAR(50),
    Subject VARCHAR(50),
    Marks INT
);

INSERT INTO Student VALUES (1,'Arun','Maths',90);
INSERT INTO Student VALUES (2,'Bala','Maths',80);
INSERT INTO Student VALUES (3,'Charan','Science',85);
INSERT INTO Student VALUES (4,'Divya','Science',95);

SELECT Subject, SUM(Marks) AS Total_Marks
FROM Student
GROUP BY Subject;



#2
SELECT 
    MAX(Marks) AS Highest_Marks,
    MIN(Marks) AS Lowest_Marks,
    AVG(Marks) AS Average_Marks
FROM Student;



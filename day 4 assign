CREATE TABLE Food (
    FoodItem VARCHAR(50),
    Category VARCHAR(50),
    Price DECIMAL(10,2)
);


INSERT INTO Food (FoodItem, Category, Price)
VALUES
('Biscuit', 'Snacks', 50.00),
('Chips', 'Snacks', 30.00),
('Pizza', 'Fast Food', 250.00),
('Burger', 'Fast Food', 120.00),
('Ice Cream', 'Dessert', 90.00),
('Juice', 'Beverages', 70.00);

SELECT Category, FoodItem, Price
FROM Food
WHERE Price < 100
GROUP BY Category, FoodItem, Price
ORDER BY Category;
